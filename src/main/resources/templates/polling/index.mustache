<!doctype html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport"
          content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Document</title>
    <style>
        * {box-sizing: border-box}
        body {
            margin: 20px;
            background-color: #f5f5f5;
            display: flex;
            justify-content : center;
            align-items: center;
        }
        .container {
            width: 500px;
            height: 600px;
            background-color: white;
            border-radius: 10px;
            display: flex;
            flex-direction: column;
            box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.2);

            overflow: hidden;
        }
        .header {
            background-color: #385ea3;
            color: white;
            text-align: center;
            padding: 15px;
        }
        .chat-box {
            flex: 1;
            background-color: white;

            overflow-y: auto;
            padding: 20px;
        }

        .msg-box {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            margin-bottom: 15px;
        }
        .name {
            font-size: 12px;
            color: #888;
            margin-bottom: 5px;
            margin-left: 5px;
        }
        .msg {
            background-color: #e9e9eb;
            padding: 10px 15px;
            border-radius: 15px;
            border-top-left-radius: 0;
            max-width: 80%;
        }

        .input-area{
            background-color: #f0f2f5;
            padding: 15px;
            border-top: 1px solid #ddd;

            display: flex;
            gap: 10px;
        }
        .input-sender {
            width: 80px;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 5px;
        }
        .input-msg {
            flex: 1;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 5px;
        }
        .btn-send {
            background-color: #385ea3;
            color: white;
            border-radius: 5px;
            border: none;
            padding: 10px;
            cursor: pointer;
        }

    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h3>Polling 채팅방 </h3>
            <p>주기적인 새로고침</p>
        </div>
        <div class="chat-box" id="chat-box">
            <!-- 반복문 처리 예정   -->
            {{#chatList}}
                <div class="msg-wrap">
                    <div class="msg-box">
                        <span class="name">{{sender}}</span>
                        <span class="msg">{{message}}</span>
                    </div>
                </div>
            {{/chatList}}
        </div>

        <form action="/polling/chat" method="post" class="input-area">
            <input type="text" name="sender" class="input-sender" value="익명" required>
            <input type="text" name="message" class="input-msg" placeholder="내용을 입력" autofocus required>
            <button type="submit" class="btn-send">전송</button>
        </form>
    </div>
    <script>
        // 1. 스크롤바 바닥 고정
        const chatBox = document.getElementById("chat-box");
        chatBox.scrollTop = chatBox.scrollHeight;

        // 2. 폴링 로직 (3초마다 새로고침 실행)
        setTimeout(() => {
            location.reload();
        }, 3000);
    </script>
</body>
</html>